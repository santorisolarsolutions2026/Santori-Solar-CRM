// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int                 @id @default(autoincrement())
  name                 String
  email                String              @unique
  phone                String?
  address              String?
  employeeId           String?             @unique
  passwordHash         String
  role                 String              // admin | sales_head | manager | tl | consultant | psa | finance | operations
  permissions          String              @default("")
  reportsTo            Int?
  isActive             Boolean             @default(true)
  lastSeenAt           DateTime?
  lastLoginAt          DateTime?
  loginLocation        String?
  lastLogoutAt         DateTime?
  logoutLocation       String?
  joiningDate          DateTime?
  photograph           String?
  workingLocation      String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  departmentId         Int?
  department           Department?         @relation(fields: [departmentId], references: [id])
  designationId        Int?
  designation          Designation?        @relation(fields: [designationId], references: [id])
  activities           Activity[]

  teamId               Int?
  team                 Team?               @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeam              Team?               @relation("TeamLeader")

  // Supervisor relation
  supervisor           User?               @relation("UserSupervisor", fields: [reportsTo], references: [id])
  subordinates         User[]              @relation("UserSupervisor")

  // Assigned Leads relations
  managedLeads         Lead[]              @relation("ManagerLeads")
  tlLeads              Lead[]              @relation("TlLeads")
  consultantLeads      Lead[]              @relation("ConsultantLeads")
  createdLeads         Lead[]              @relation("LeadCreator")

  // Other relationships
  logs                 LeadActivityLog[]
  assignedMeetings     MeetingBooking[]    @relation("MeetingExecutive")
  submittedOrders      Order[]             @relation("SubmittedOrders")
  verifiedOrders       Order[]             @relation("VerifiedOrders")
  uploadedDocuments    OrderDocument[]
  notifications        Notification[]
  attendances          Attendance[]
  recordedPayments     Payment[]
}

model Lead {
  id                   Int                 @id @default(autoincrement())
  leadCode             String              @unique
  customerName         String
  mobile               String              @unique
  mobileAlt            String?
  connectionType       String              // residential | commercial | industrial
  sanctionedLoadKw     Float?
  address              String
  pinCode              String
  city                 String
  state                String
  leadSource           String?             // whatsapp | cold_call | referral | walk_in | google_ad | other
  status               Int                 @default(1) // 1 to 14
  statusSub            String?             // For Stage 3: warm | hot. For Stage 12: reason, etc.
  assignedManagerId    Int?
  assignedTlId         Int?
  assignedConsultantId Int?
  followupAt           DateTime?
  isUnreachable        Boolean             @default(false)
  isActive             Boolean             @default(true)
  createdById          Int
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  otherData            String?
  discomName           String?
  connectionNumber     String?
  assignedTeamId       Int?

  // Relations
  manager              User?               @relation("ManagerLeads", fields: [assignedManagerId], references: [id])
  tl                   User?               @relation("TlLeads", fields: [assignedTlId], references: [id])
  consultant           User?               @relation("ConsultantLeads", fields: [assignedConsultantId], references: [id])
  creator              User                @relation("LeadCreator", fields: [createdById], references: [id])
  assignedTeam         Team?               @relation("TeamLeads", fields: [assignedTeamId], references: [id])

  activityLogs         LeadActivityLog[]
  meetings             MeetingBooking[]
  order                Order?
  notifications        Notification[]
  activities           Activity[]

  @@index([mobile])
  @@index([status])
  @@index([assignedConsultantId])
  @@index([assignedManagerId])
}

model LeadActivityLog {
  id                   Int                 @id @default(autoincrement())
  leadId               Int
  userId               Int
  fromStatus           Int?
  toStatus             Int
  remark               String?
  createdAt            DateTime            @default(now())

  // Relations
  lead                 Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user                 User                @relation(fields: [userId], references: [id])

  @@index([leadId])
}

model MeetingBooking {
  id                   Int                 @id @default(autoincrement())
  leadId               Int
  address              String
  pinCode              String
  mobile               String
  mobileAlt            String?
  meetingDate          String              // YYYY-MM-DD
  meetingTime          String              // HH:MM
  avgMonthlyBill       Float
  connectionType       String              // residential | commercial | industrial
  assignedExecutiveId  Int
  notes                String?
  createdAt            DateTime            @default(now())

  // New fields for Start/End Meeting, Location & Audio Recording
  meetingLatitude      Float?
  meetingLongitude     Float?
  meetingCity          String?
  meetingLocality      String?
  meetingPinCode       String?
  audioRecordingPath   String?
  meetingDurationSec   Int?
  meetingStartedAt     DateTime?
  meetingEndedAt       DateTime?

  // Relations
  lead                 Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  executive            User                @relation("MeetingExecutive", fields: [assignedExecutiveId], references: [id])
}

model Order {
  id                   Int                 @id @default(autoincrement())
  leadId               Int                 @unique
  orderCode            String              @unique
  connectionNumber     String
  systemSizeKw         Float
  totalValue           Float
  downPayment          Float
  paymentMethod        String              // cash | upi | cheque | neft | bank_transfer
  transactionRef       String?
  remainingMethod      String              // finance | cash | emi
  financeProvider      String?
  clientType           String              // on_grid | off_grid | hybrid
  subsidyApplicable    Boolean
  subsidyAmount        Float?
  additionalNotes      String?
  rejectionReason      String?
  submittedById        Int
  financeProcessedById Int?
  status               String              @default("draft") // draft | submitted | finance_verified | ops_assigned | completed
  opsStage             Int                 @default(1)
  deliveryDate         String?
  deliveryTime         String?
  isDelivered          Boolean             @default(false)
  actualDeliveryAt     DateTime?
  installationDate     String?
  installationTime     String?
  isInstalled          Boolean             @default(false)
  actualInstallationAt DateTime?
  isMeterInstalled     Boolean             @default(false)
  actualMeterInstalledAt DateTime?
  isCommissioned       Boolean             @default(false)
  actualCommissionedAt DateTime?
  isSubsidyApplied     Boolean             @default(false)
  actualSubsidyAppliedAt DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Relations
  lead                 Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  submittedBy          User                @relation("SubmittedOrders", fields: [submittedById], references: [id])
  financeProcessedBy   User?               @relation("VerifiedOrders", fields: [financeProcessedById], references: [id])
  documents            OrderDocument[]
  installationImages   InstallationImage[]
  payments             Payment[]
}

model InstallationImage {
  id         Int      @id @default(autoincrement())
  orderId    Int
  status     String   // in_progress | completed
  filePath   String
  fileName   String
  uploadedAt DateTime @default(now())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderDocument {
  id                   Int                 @id @default(autoincrement())
  orderId              Int
  docType              String              // aadhaar | pan | electricity_bill | bank_passbook
  filePath             String
  fileName             String
  fileSizeOctets       Int
  mimeType             String
  uploadedById         Int
  uploadedAt           DateTime            @default(now())

  // Relations
  order                Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploader             User                @relation(fields: [uploadedById], references: [id])
}

model Notification {
  id                   Int                 @id @default(autoincrement())
  userId               Int
  type                 String              // meeting_booked | sale_done | follow_up | etc.
  title                String
  body                 String
  leadId               Int?
  isRead               Boolean             @default(false)
  createdAt            DateTime            @default(now())

  // Relations
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead                 Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Attendance {
  id                   Int                 @id @default(autoincrement())
  userId               Int
  date                 DateTime            @db.Date
  checkIn              DateTime
  checkOut             DateTime?
  checkInLocation      String?
  checkOutLocation     String?
  workDurationMin      Int?
  status               String              @default("checked_in") // checked_in | completed | late | half_day
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Payment {
  id             Int      @id @default(autoincrement())
  orderId        Int
  amount         Float
  paymentMethod  String   // cash | upi | cheque | neft | bank_transfer
  transactionRef String?
  paymentDate    DateTime @default(now())
  remarks        String?
  recordedById   Int
  receiptUrl     String?
  isDiscarded    Boolean  @default(false)
  discardReason  String?
  changeReason   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recordedBy     User     @relation(fields: [recordedById], references: [id])

  @@index([orderId])
}

model Department {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  users        User[]
  designations Designation[]
  teams        Team[]
}

model Designation {
  id           Int         @id @default(autoincrement())
  name         String      @unique
  level        Int
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users        User[]
}

model Activity {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  employee       User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leadId         Int?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activityType   String   // MEETING_BOOKED | SALE_DONE | CALL_MADE | FOLLOW_UP | ORDER_APPROVED | ORDER_REJECTED | INSTALLATION_COMPLETED | etc.
  createdAt      DateTime @default(now())
  metadata       String?  // JSON string

  @@index([employeeId])
  @@index([leadId])
  @@index([activityType])
}

model GazettedHoliday {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique
  name      String
  createdAt DateTime @default(now())
}

model Team {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  leaderId     Int?       @unique
  leader       User?      @relation("TeamLeader", fields: [leaderId], references: [id])
  members      User[]     @relation("TeamMembers")
  leads        Lead[]     @relation("TeamLeads")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

